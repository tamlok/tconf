pane_frames false
theme "nord"
scroll_buffer_size 100000
scrollback_editor "nvim"
web-server false
// default_cwd "C:/Users/Sydney"
default_shell "nu"

keybinds {
    locked {
        bind "Ctrl g" { SwitchToMode "Normal"; }
        bind "Ctrl [" { Write 27; }
    }
    normal {
        bind "Ctrl g" { Write 7; SwitchToMode "Locked"; }
    }
}

default_mode "locked"
show_startup_tips false
