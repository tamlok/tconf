{
  "lsp": {
    "clangd": {
      "command": [
        "clangd",
        "--background-index"
      ],
      "extensions": [
        ".c",
        ".cpp",
        ".h",
        ".hpp",
        ".cc",
        ".cxx"
      ]
    },
    "typescript": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".mjs",
        ".cjs"
      ]
    }
  },
  "agents": {
    "explore": {
      "model": "github-copilot/claude-opus-4.7-1m-internal"
    },
    "librarian": {
      "model": "github-copilot/claude-opus-4.7-1m-internal"
    },
    "oracle": {
      "model": "github-copilot/claude-opus-4.7-1m-internal",
      "variant": "high"
    },
    "prometheus": {
      "model": "github-copilot/claude-opus-4.7-1m-internal",
      "variant": "high"
    },
    "sisyphus": {
      "model": "github-copilot/claude-opus-4.7-1m-internal",
      "variant": "high",
      "ultrawork": {
        "model": "github-copilot/claude-opus-4.7-1m-internal",
        "variant": "high"
      }
    },
    "metis": {
      "model": "github-copilot/gpt-5.5",
      "variant": "high"
    },
    "momus": {
      "model": "github-copilot/gpt-5.5",
      "variant": "high"
    },
    "atlas": {
      "model": "github-copilot/claude-opus-4.7-1m-internal"
    },
    "hephaestus": {
      "model": "github-copilot/gpt-5.5",
      "variant": "high"
    },
    "multimodal-looker": {
      "model": "github-copilot/gemini-3-pro-preview",
      "variant": "high"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "github-copilot/claude-opus-4.7-1m-internal",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "github-copilot/gpt-5.5",
      "variant": "xhigh"
    },
    "artistry": {
      "model": "github-copilot/claude-opus-4.7-1m-internal",
      "variant": "high"
    },
    "deep": {
      "model": "github-copilot/claude-opus-4.7-1m-internal",
      "variant": "high"
    },
    "quick": {
      "model": "github-copilot/claude-haiku-4.5"
    },
    "unspecified-low": {
      "model": "github-copilot/claude-haiku-4.5"
    },
    "unspecified-high": {
      "model": "github-copilot/claude-opus-4.7-1m-internal",
      "variant": "high"
    },
    "writing": {
      "model": "github-copilot/claude-opus-4.7-1m-internal",
      "variant": "high"
    }
  },
  "background_task": {
    "defaultConcurrency": 10,
    "providerConcurrency": {
      "github-copilot": 10
    }
  },
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/master/assets/oh-my-openagent.schema.json"
}
