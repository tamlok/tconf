{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-opus-4.8",
  "permission": {
    "bash": {
      "rg *": "allow"
    }
  },
  "theme": "everforest",
  "snapshot": false,
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "provider": {
    "github-copilot": {
      "options": {
        "headers": {
          "Copilot-Integration-Id": "copilot-4-cli"
        }
      }
    }
  }
}
